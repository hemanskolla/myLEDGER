{
  "name": "client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start:client": "vite --config client/vite.config.ts",
    "start:server": "tsx server/server.ts",
    "start": "concurrently -n client,server \"npm run start:client\" \"npm run start:server\"",
    "build": "tsc -b && vite build --config client/vite.config.ts",
    "lint": "eslint .",
    "preview": "vite preview --config client/vite.config.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "mongodb": "^6.17.0",
    "express": "^5.2.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
